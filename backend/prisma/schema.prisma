generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  pushToken     String?
  role               String   @default("member")
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  ownedTeams    Team[]         @relation("TeamOwner")
  teams         Team[]         @relation("TeamMembers")
  createdAt     DateTime       @default(now())
  meetings      Meeting[]
  assignedTasks Task[]         @relation("TaskAssignee")
  speakerLabels MeetingSpeaker[]
  notifications Notification[]
}

model Meeting {
  id           String       @id @default(cuid())
  ownerId      String
  owner        User         @relation(fields: [ownerId], references: [id])
  title        String
  status       String       @default("recording")
  audioUrl     String?
  durationSec  Int?
  goal         String?
  summary      String?
  errorMessage String?
  transcript   Transcript?
  tasks        Task[]
  speakers     MeetingSpeaker[]
  createdAt    DateTime     @default(now())
  teamId       String?
  team         Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  searchVector Unsupported("tsvector")? @default(dbgenerated("((setweight(to_tsvector('english'::regconfig, COALESCE(title, ''::text)), 'A'::\"char\") || setweight(to_tsvector('english'::regconfig, COALESCE(goal, ''::text)), 'B'::\"char\")) || setweight(to_tsvector('english'::regconfig, COALESCE(summary, ''::text)), 'C'::\"char\"))"))

  @@index([ownerId])
  @@index([teamId])
  @@index([searchVector], type: Gin)
}

model Team {
  id        String    @id @default(cuid())
  ownerId   String
  owner     User      @relation("TeamOwner", fields: [ownerId], references: [id])
  name      String
  members   User[]    @relation("TeamMembers")
  meetings  Meeting[]
  createdAt DateTime  @default(now())

  @@index([ownerId])
}

model Transcript {
  id        String   @id @default(cuid())
  meetingId String   @unique
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  fullText  String
  segments  Json?
  createdAt DateTime @default(now())
  searchVector Unsupported("tsvector")? @default(dbgenerated("to_tsvector('english'::regconfig, COALESCE(\"fullText\", ''::text))"))

  @@index([searchVector], type: Gin)
}

model Task {
  id                   String    @id @default(cuid())
  meetingId            String
  meeting              Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  description          String
  assigneeId           String?
  assignee             User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assigneeText         String?
  assigneeSpeakerLabel String?
  suggestedAssigneeIds String[]
  status               String    @default("needs_assignee")
  notifiedAt           DateTime?
  createdAt            DateTime  @default(now())
  searchVector         Unsupported("tsvector")? @default(dbgenerated("to_tsvector('english'::regconfig, ((COALESCE(description, ''::text) || ' '::text) || COALESCE(\"assigneeText\", ''::text)))"))

  @@index([meetingId])
  @@index([assigneeId])
  @@index([searchVector], type: Gin)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  taskId    String
  meetingId String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model MeetingSpeaker {
  id         String   @id @default(cuid())
  meetingId  String
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  label      String   // diarization label as emitted by AssemblyAI: "A", "B", ...
  userId     String?  // resolved app user (null for guest / unknown)
  user       User?    @relation(fields: [userId], references: [id])
  guestName  String?  // free-text name when the speaker is not an app user
  confidence String   @default("unknown") // Claude's guess confidence: high | low | unknown
  confirmed  Boolean  @default(false)     // owner explicitly confirmed / corrected
  createdAt  DateTime @default(now())

  @@unique([meetingId, label])
  @@index([meetingId])
  @@index([userId])
}
