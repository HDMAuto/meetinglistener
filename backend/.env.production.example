# Copy to backend/.env on the server and fill in real values.
# Generate JWT_SECRET with:  openssl rand -hex 32

NODE_ENV=production

# Your existing Postgres on the server. Create the DB + user first (see runbook).
DATABASE_URL="postgresql://meetinglistener:CHANGE_ME_DB_PASSWORD@localhost:5432/meetinglistener?schema=public"

JWT_SECRET="CHANGE_ME_openssl_rand_hex_32"

PORT=3000
UPLOAD_DIR="uploads"

ANTHROPIC_API_KEY="sk-ant-..."
ASSEMBLYAI_API_KEY="..."

# Optional: only needed if a BROWSER (the web dashboard) will hit this API.
# The desktop (Electron) and mobile (native) apps do NOT need this.
# Comma-separated, no trailing slash. Leave unset if you only ship desktop+mobile.
# ALLOWED_ORIGINS="https://meetings.hdmauto.app"
