{
  "expo": {
    "name": "MeetingListener",
    "slug": "meetinglistener",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.meetinglistener.mobile"
    },
    "android": {
      "package": "app.meetinglistener.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "MeetingListener records meeting audio so it can transcribe and summarize your meetings."
        }
      ],
      "expo-font"
    ]
  }
}
